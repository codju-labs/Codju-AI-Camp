---
import PortalLayout from "../layouts/PortalLayout.astro";
---

<PortalLayout title="Enrollment Required" showHeader={false}>
  <main class="flex min-h-screen items-center justify-center bg-gradient-to-br from-purple-50 via-white to-indigo-50 px-4 py-12">
    <section class="w-full max-w-lg rounded-3xl border-2 border-purple-100 bg-white p-8 text-center shadow-xl md:p-10">
      <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-purple-100 text-purple-700">
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 0 0 2-2v-6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2Zm10-10V7a4 4 0 0 0-8 0v4"></path>
        </svg>
      </div>
      <p class="mb-2 text-xs font-bold uppercase tracking-widest text-purple-600">Enrollment check</p>
      <h1 class="mb-3 text-2xl font-extrabold text-gray-800 md:text-3xl">We could not find portal access</h1>
      <p class="mb-7 text-sm leading-relaxed text-gray-500 md:text-base">
        You may have paid using a parent's email and signed in with a student's email. Send us both addresses and we will connect them.
      </p>
      <div class="flex flex-col justify-center gap-3 sm:flex-row">
        <a href="mailto:info@codju.com?subject=AI%20Creator%20Camp%20Portal%20Access" class="rounded-full border-2 border-[#8623d5] bg-[#8623d5] px-6 py-3 text-sm font-bold text-white no-underline">
          Contact support
        </a>
        <a href="/api/auth/signout" class="rounded-full border-2 border-purple-200 px-6 py-3 text-sm font-bold text-purple-700 no-underline">
          Try another account
        </a>
      </div>
    </section>
  </main>
</PortalLayout>
